# ── AI Backend ────────────────────────────────────────────────────────────────
# Choose "anthropic" (cloud) or "ollama" (local/free).
ANALYZER_BACKEND=anthropic

# Anthropic — only needed when ANALYZER_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama — only needed when ANALYZER_BACKEND=ollama
# Recommended for 8 GB M2 MacBook Air: llava:7b (~4.1 GB, runs on Metal GPU)
# Pull first:  ollama pull llava:7b
# Avoid llama3.2-vision:11b on 8 GB — it will swap heavily.
OLLAMA_MODEL=llava:7b
OLLAMA_HOST=http://localhost:11434

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=youraddress@gmail.com
SMTP_RECIPIENT=alerts@example.com

# ── Camera ────────────────────────────────────────────────────────────────────
# -1 = prompt at startup to select from detected cameras
CAMERA_INDEX=-1

# CAMERA_FLIP — rotate/flip the captured image
#   none       = no flip (default)
#   180        = rotate 180° — use this if your camera is mounted upside-down
#   vertical   = flip top-to-bottom
#   horizontal = flip left-to-right
CAMERA_FLIP=none

# ── Detection ─────────────────────────────────────────────────────────────────
# Send alert when confidence >= this value (0.0 – 1.0)
# Consider raising to 0.80 with Ollama — local models can be overconfident.
CONFIDENCE_THRESHOLD=0.70

# ── Metrics & Output ──────────────────────────────────────────────────────────
METRICS_PORT=8000
TIMELAPSE_DIR=timelapse_frames

# ── Printer USB control (optional) ────────────────────────────────────────────
# Connect the printer's USB-C port to this machine for live temps and to
# auto-pause a print when a failure is confirmed.
#   PRINTER_PORT — serial device. Leave blank to disable. "auto" tries to
#                  detect it. On macOS it looks like /dev/tty.usbserial-XXXX
#                  or /dev/tty.usbmodemXXXX (run: ls /dev/tty.* with it plugged in).
#   PRINTER_BAUD — almost always 115200 for the Ender 3 V3 SE.
PRINTER_PORT=
PRINTER_BAUD=115200

# Auto-intervene when a failure is CONFIRMED (after the consecutive-frame check).
#   AUTO_PAUSE_ON_FAILURE — true/false
#   AUTO_PAUSE_ACTION — pause    : M25 (pause SD print)
#                       cooldown : pause + turn off hotend/bed/fan
#                       estop    : M112 emergency stop (requires power-cycle after)
AUTO_PAUSE_ON_FAILURE=false
AUTO_PAUSE_ACTION=pause

# ── Push notifications (optional) ─────────────────────────────────────────────
# Any combination can be enabled; alerts fire to all configured channels.
#   ntfy     — easiest, no account: pick a unique topic, install the ntfy app,
#              subscribe to the same topic. Set NTFY_TOPIC to that name.
#   Discord  — paste a channel webhook URL.
#   Telegram — create a bot with @BotFather, then get your chat id.
NTFY_TOPIC=
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
