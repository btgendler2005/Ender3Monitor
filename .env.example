# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Email alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=youraddress@gmail.com
SMTP_RECIPIENT=alerts@example.com

# Camera (-1 = prompt at startup to select from detected cameras)
CAMERA_INDEX=-1

# Failure alert threshold (0.0 – 1.0); alerts sent when confidence >= this value
CONFIDENCE_THRESHOLD=0.70

# Prometheus metrics port
METRICS_PORT=8000

# Directory for timelapse frames
TIMELAPSE_DIR=timelapse_frames
